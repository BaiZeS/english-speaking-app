# ====== 应用 ======
ENV=development
DEBUG=true

# ====== 数据库 ======
DATABASE_URL=postgresql+asyncpg://english:english@localhost:5432/english_dev
REDIS_URL=redis://localhost:6379/0

# ====== 讯飞 (主) ======
XUNFEI_APP_ID=
XUNFEI_API_KEY=
XUNFEI_API_SECRET=

# ====== 讯飞 TTS ======
# 默认走超拟人 Spark TTS (https://www.xfyun.cn/doc/spark/super%20smart-tts.html),
# vcn 命名空间 x5_* / x6_*. 控制台「超拟人语音合成」开通后即生效, 不需要授权具体发音人.
# 美式英文: x5_EnUs_Grant_flow (默认, 沉稳) / x5_EnUs_Lila_flow (年轻柔和)
XUNFEI_TTS_DEFAULT_VCN=x5_EnUs_Grant_flow
# 支持的发音人列表（逗号分隔），app 设置页可切换
XUNFEI_TTS_VOICES=x5_EnUs_Grant_flow,x5_EnUs_Lila_flow

# ====== 讯飞 超拟人 Spark TTS ======
# APIPassword: 在「超拟人语音合成」控制台获取. 鉴权用请求头 x-api-key: <password>.
# 不配则自动 fallback 到 v2 老接口 (XUNFEI_API_KEY/SECRET), 再降级到 stub.
XUNFEI_SPARK_TTS_PASSWORD=

# ====== OpenAI / 阿里 (备选) ======
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ALIYUN_DASHSCOPE_KEY=


# ====== LLM (自由对话) ======
# OpenAI 兼容端点 (阿里云百炼 Maas / OpenAI / 其它第三方代理都行).
# 留空时 /dialogue/* 自动回退到内置 deterministic fallback.
LLM_BASE_URL=https://ws-mtamw1iiqigfyzxq.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-b162c5f9264f44158cab6d39b28f648b
LLM_DEFAULT_MODEL=qwen-plus
# 逗号分隔的模型白名单, 限制客户端可选范围; 留空则用代码内置的百炼目录.
LLM_ALLOWED_MODELS=
# JSON 数组, 给企业自建代理场景追加自定义模型
LLM_EXTRA_MODELS_JSON=

# ====== App 版本 (自动更新) ======
# 客户端启动时拉取 /api/v1/app/version 比较, 大于当前版本就弹更新.
APP_LATEST_VERSION=1.0.0
APP_APK_URL=
APP_RELEASE_NOTES=
# 强制升级门槛, 留空表示不强制升级; 设置后小于此版本的客户端必须升级才能用.
APP_MIN_SUPPORTED_VERSION=

# ====== TTS 缓存 ======
TTS_CACHE_TTL=86400
