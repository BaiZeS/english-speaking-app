# ====== 应用 ======
ENV=development
DEBUG=true

# ====== 数据库 ======
DATABASE_URL=postgresql+asyncpg://english:english@localhost:5432/english_dev
REDIS_URL=redis://localhost:6379/0

# ====== 讯飞 (主) ======
XUNFEI_APP_ID=
XUNFEI_API_KEY=
XUNFEI_API_SECRET=

# ====== 讯飞 TTS ======
# 发音人 vcn（在控制台开通「在线语音合成」并添加发音人后生效）
XUNFEI_TTS_DEFAULT_VCN=xiaoyan
# 支持的发音人列表（逗号分隔），app 设置页可切换
XUNFEI_TTS_VOICES=xiaoyan,x4_xiaoyan

# ====== OpenAI / 阿里 (备选) ======
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ALIYUN_DASHSCOPE_KEY=

# ====== TTS 缓存 ======
TTS_CACHE_TTL=86400
