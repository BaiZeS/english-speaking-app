# ====== 应用 ======
ENV=development
DEBUG=true

# ====== 数据库 ======
DATABASE_URL=postgresql+asyncpg://english:english@localhost:5432/english_dev
REDIS_URL=redis://localhost:6379/0

# ====== 讯飞 (主) ======
XUNFEI_APP_ID=
XUNFEI_API_KEY=
XUNFEI_API_SECRET=

# ====== 讯飞 TTS ======
# 默认走超拟人 Spark TTS (https://www.xfyun.cn/doc/spark/super%20smart-tts.html),
# vcn 命名空间 x5_* / x6_*. 控制台「超拟人语音合成」开通后即生效, 不需要授权具体发音人.
# 美式英文: x5_EnUs_Grant_flow (默认, 沉稳) / x5_EnUs_Lila_flow (年轻柔和)
XUNFEI_TTS_DEFAULT_VCN=x5_EnUs_Grant_flow
# 支持的发音人列表（逗号分隔），app 设置页可切换
XUNFEI_TTS_VOICES=x5_EnUs_Grant_flow,x5_EnUs_Lila_flow

# ====== 讯飞 超拟人 Spark TTS ======
# APIPassword: 在「超拟人语音合成」控制台获取. 鉴权用请求头 x-api-key: <password>.
# 不配则自动 fallback 到 v2 老接口 (XUNFEI_API_KEY/SECRET), 再降级到 stub.
XUNFEI_SPARK_TTS_PASSWORD=

# ====== OpenAI / 阿里 (备选) ======
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ALIYUN_DASHSCOPE_KEY=

# ====== TTS 缓存 ======
TTS_CACHE_TTL=86400
